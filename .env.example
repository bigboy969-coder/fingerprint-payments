# FingerPay — Environment Variables
# Copy to .env and fill in real values. Never commit .env itself.
# See docs/OPERATIONS.md for full details on each variable.

# ── Required ─────────────────────────────────────────────────────────────────

# HMAC key for all JWTs. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: if unset, falls back to a hardcoded dev value — NEVER deploy without setting this.
FINGERPAY_SECRET=

# AES-256 key for fingerprint descriptor encryption. 64 hex chars (32 bytes).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Loss of this key = all biometrics permanently inaccessible.
BIOMETRIC_ENCRYPTION_KEY=

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base URL of the deployed app (used in reset emails, Connect return URLs)
APP_BASE_URL=http://localhost:8000

# ── Required in production ───────────────────────────────────────────────────

# PostgreSQL connection string. Omit for SQLite (local dev only).
# DATABASE_URL=postgres://user:pass@host:5432/fingerpay

# Resend API key for transactional emails (password reset, verification codes).
# Without this, emails are silently skipped.
# RESEND_API_KEY=re_...

# Stripe webhook signing secret (from Stripe Dashboard > Webhooks > Signing secret).
# Required for /webhooks/stripe to verify inbound events.
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for the $99/month merchant subscription.
# Create a recurring price in Stripe Dashboard > Products, then paste the price_... ID here.
# Required in production for POST /merchants/billing/setup to work.
# STRIPE_PRICE_ID=price_...

# ── Optional ─────────────────────────────────────────────────────────────────

# Directory for SQLite DB file (default: repo root). Dev only.
# DATA_DIR=/tmp/fingerpay

# Port — usually set by the hosting platform, not manually.
# PORT=8000
